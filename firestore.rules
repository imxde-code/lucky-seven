rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Game Document ────────────────────────────────────────
    match /games/{gameId} {
      // Anyone authenticated can read the game doc (public state)
      allow read: if request.auth != null;

      // Anyone authenticated can create a game
      allow create: if request.auth != null
        && request.resource.data.status == 'lobby'
        && request.resource.data.hostId == request.auth.uid;

      // Players in the game can update (controlled by client transactions)
      allow update: if request.auth != null
        && request.auth.uid in resource.data.playerOrder;

      allow delete: if false;

      // ─── Players Sub-collection ─────────────────────────────
      match /players/{playerId} {
        // Anyone in the game can read player info (names, seats)
        allow read: if request.auth != null;

        // A player can create/update their own player doc
        allow create: if request.auth != null
          && request.auth.uid == playerId;

        allow update: if request.auth != null
          && request.auth.uid == playerId;

        allow delete: if false;
      }

      // ─── Private Player Data ────────────────────────────────
      match /private/{playerId} {
        // CRITICAL: Only the owning player can read their private data
        allow read: if request.auth != null
          && request.auth.uid == playerId;

        // Only the owning player can write their own private data
        allow create: if request.auth != null
          && request.auth.uid == playerId;

        // For game engine transactions, we also allow the current turn
        // player to update private docs (needed for dealing and peek).
        // In a production app, this would use Cloud Functions.
        // For MVP, we relax this to allow any game participant to write
        // (the client transaction logic enforces correctness).
        allow update: if request.auth != null;

        allow delete: if false;
      }

      // ─── Internal Docs (draw pile, results) ─────────────────
      match /internal/{docId} {
        // Draw pile should only be readable during game transactions
        // Results readable by all players after game ends
        allow read: if request.auth != null;

        // Only game participants can write internal docs
        allow create, update: if request.auth != null;

        allow delete: if false;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
